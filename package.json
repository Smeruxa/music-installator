{
    "name": "music-installator",
    "version": "1.0.0",
    "description": "VK Music Installer — download your VK music library",
    "main": "./out/main/index.js",
    "author": "Smeruxa",
    "license": "MIT",
    "private": true,
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "dist": "npm run build && electron-builder --config electron-builder.yml",
        "dist:mac": "npm run build && electron-builder --config electron-builder.yml --mac",
        "dist:win": "npm run build && node scripts/fetch-ffmpeg-win.mjs && electron-builder --config electron-builder.yml --win --x64 && node scripts/restore-ffmpeg-host.mjs",
        "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"**/*.{ts,tsx,js,scss,json,yml,md}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,scss,json,yml,md}\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@tanstack/react-virtual": "^3.14.8",
        "ffmpeg-static": "^5.2.0",
        "hls.js": "^1.6.16",
        "mobx": "^6.16.1",
        "mobx-react-lite": "^4.1.1",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "react-icons": "^5.7.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.5",
        "@types/node": "^22.17.0",
        "@types/react": "^19.1.9",
        "@types/react-dom": "^19.1.7",
        "@vitejs/plugin-react": "^4.7.0",
        "@vitest/coverage-v8": "^4.1.10",
        "electron": "^37.2.5",
        "electron-builder": "^26.15.3",
        "electron-vite": "^5.0.0",
        "eslint": "^9.39.5",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.7.0",
        "jsdom": "^29.1.1",
        "prettier": "^3.9.6",
        "sass": "^1.101.3",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.65.0",
        "vite": "^7.0.6",
        "vitest": "^4.1.10"
    }
}
